#Takes into account shared peptides, ambiguos sites

#pdata 12
pdata12<-pdata8
pdata12 <- pdata12 %>%
  mutate(
    
#mutate() - used to add new columns or modify existing ones in a data frame, all within a readable pipeline.
# %>% = “then do this”:

    # Flag multi-protein rows
    SharedPeptide = str_detect(Accessions, ";"), 
    
    #str_detect(string, pattern) returns: a column that has TRUE → if the pattern is found 
    # FALSE → if NOT found
    
    # Clean accession formatting
    ProteinAccession_clean = gsub(";\\s*", ";", Accessions), #Q8NE71; Q5STZ8 Becomes Q8NE71;Q5STZ8
    
    #gsub() = global substitution = gsub(pattern, replacement, x)
    #\\s* =\\s = space; *=any no of times, replace with ; of column accessions
    
    # Extract resolved phosphosites only
    
    raw_sites = str_extract_all(Modifications, "Phospho \\[[^\\]]+\\]"),
    
    #Match any sequence of characters as long as they are NOT a closing bracket after Phospho in []
    #Finds Phospho tags that contain specific site information inside brackets and not Acetyl/ HexNAc tags
    #eg. 1 row of rawsites = Phospho [S151; S153]; Phospho [S149; S151]
    
    Sites = map(raw_sites, ~ str_extract_all(.x, "[STY][0-9]+") %>% unlist()),
    
  #map(raw_sites, ...) applies the function str_extract_all to each element of the list rawsites.
  #Inside the function, str_extract_all(.x, "[STY][0-9]+") extracts all phosphosites from each bracket string.
  #%>% unlist() flattens the results (which is itself a list) into a simple character vector per element.
  #The final result, Sites, is a list-column of character vectors of phosphosites per row [S106, S205, S310]
  
  #O/P=Sitse = S151; S153; S149; S151
  
    # Combine multiple sites safely
    SiteCombined = map_chr(Sites, function(x) { 
      
    #map_chr() applies a function to each element of a list or vector and returns a character vector.
    #(unlike map() which keeps it as a list)
     
      #Site = S151; S153; S149; S151
      
      if(length(x) == 0) return(NA_character_) # handle empty lists - gives NA
      
      #if length of Site==0 gives NA
      
      residues <- substr(x, 1, 1) # ["S", "S", "S", "S"] from [S151; S153; S149; S151]
      
      #substr(string, start, stop) extracts a substring from start to stop
     
      
      numbers  <- gsub("[STY]", "", x) # ["151", "153", "149" "151"] from [S151; S153; S149; S151]
      
      #gsub(pattern, replacement, x) → replaces all matches of pattern with replacement in x
      
        paste(x, collapse = "/") 
        
      #x is each element of the Sites list, x <- c("S106", "T205", "Y17") collapsed as (S106/T205/Y17) 
     #O/P: SiteCombined = S151/153/149/151
    }),

# Create SiteID (ambiguous stays ambiguous)


SiteID = purrr::pmap_chr( 
  
  #pmap = parallel map across multiple inputs; chr = return character output
  
  list(ProteinAccession_clean, raw_sites, SiteCombined),
  function(prot_col, site_col, SiteComb) {
    
    #prot_col=ProteinAccession_clean Q8NE71;Q5STZ8; 
    #site_col=raw_sites = Phospho [S151; S153]; Phospho [S149; S151]
    #SiteComb =SiteCombined = S151/153/149/151
    
    if (is.na(prot_col) | is.na(SiteComb)) return(NA_character_)
    
    if (!str_detect(prot_col, ";")) {
      return(paste0(prot_col, "_", SiteComb)) 
    
      #if did not detect ; in Q8NE71;Q5STZ8 i.e; Q8NE71 only detected, 
      #Paste Q8NE71_S151/153 (ProteinAccession_clean and Site Combined)
      
      }
    
    # 1. Split proteins into a vector
    prots <- str_split(prot_col, ";")[[1]] #protol=ProteinAccession_clean = Q8NE71;Q5STZ8
    
    #str_split returns a LIST containing one character vector
    #[[1]] = extracts items inside the list
    #If you forgot the [[1]] and tried to use prots[1], you would get the entire list back
    #instead of the first protein ID. Using [[1]] ensures you are working with the data itself rather than the "container" it came in.
    
    #prots isolate individual protein accessions when multiple proteins are listed in a single cell with ;
    #O/P: prots= "Q8NE71" "Q5STZ8"
    
   
     # 2. Split raw sites into individual groups 
    phospho_parts <- str_split(site_col, "(?<=\\]);\\s*") 
    
    #site_col=raw_sites =  Phospho [S151; S153]; Phospho [S149; S151]
    
    # (?<=\\]) = look for: after ] if find ; \\s=space *= any no of times , 
    #splt string Phospho [S151; S153]; Phospho [S149; S151]
    
    #O/P phospho_parts="Phospho [S151; S153]" "Phospho [S149; S151]"
  
    # 3. Extract content inside brackets (e.g., [S151; S153] becomes [S151/S153])
    clean_sites <- str_extract(phospho_parts, "(?<=\\[).*(?=\\])") %>% 
    str_replace_all(";", "/") 
    
    #str_extract = pulls everything within bracket
    #. (The Dot):  matches any single character (except for a newline)
    #phospho_parts="Phospho [S151; S153]" "Phospho [S149; S151]" becomes
    #O/P clean_sites = "S151/S153" "S149/S151"
    
    # 4. Combine: Protein_Site (e.g., "a_s22,s33")
    combined_vec <- paste(prots, clean_sites, sep = "_")
    
    #O/P: prots= "Q8NE71" "Q5STZ8"
    #O/P clean_sites = "S151/S153" "S149/S151"
    #O/P combined_vec = "Q8NE71_S151/S153" "Q5STZ8_S149/S151"
    
    # 5. Collapse back to one string
    return(paste(combined_vec, collapse = ";"))
    
    #O/P SiteID = "Q8NE71_S151/S153;Q5STZ8_S149/S151"
    
    }))
     
