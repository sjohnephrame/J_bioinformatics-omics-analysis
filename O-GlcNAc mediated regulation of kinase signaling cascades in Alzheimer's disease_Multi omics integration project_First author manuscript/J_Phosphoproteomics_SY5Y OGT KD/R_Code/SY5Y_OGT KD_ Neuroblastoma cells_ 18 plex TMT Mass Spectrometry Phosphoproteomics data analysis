#---------------------------------------------------------------------------------------#
# For Loop: Generate Data Files and Print Detailed Verification (Head & Dim)
#---------------------------------------------------------------------------------------#

# 1. Use your established list of 7 treatment comparison names
comparisons <- c(
  "GFPTEN.GFPCTRL", 
  "OGTTEN.OGTCTRL", 
  "ROGTTEN.ROGTCTRL", 
  "OGTCTRL.GFPCTRL", 
  "OGTTEN.GFPTEN", 
  "ROGTCTRL.GFPCTRL", 
  "ROGTTEN.GFPTEN"
)

# 2. Run the loop to generate the heatmap, subset, and full ordered files
for (comp in comparisons) {
  
  # Construct the input variable name from your p-value filtering loop
  input_var_name <- paste0("rem.sort.updown.", comp)
  
  # Fetch the data frame from your environment workspace
  sig_only <- get(input_var_name, envir = .GlobalEnv)
  
  # Find the exact column names for logFC and adj.P.Val
  logfc_col <- paste0("logFC.", comp)
  adj_p_col <- paste0("adj.P.Val.", comp)
  
  # Skip comparisons with fewer than 40 total significant rows (like GFPTEN.GFPCTRL)
  if (nrow(sig_only) < 40) {
    cat(paste0("==============================================================\n",
               "SKIPPING COMPARISON: ", comp, "\n",
               "Only has ", nrow(sig_only), " significant rows (need at least 40).\n",
               "==============================================================\n\n"))
    next
  }
  
  # --- Step 2: Get ALL Up-regulated sorted (Highest positive logFC to lowest) ---
  ordered_up_all <- sig_only[order(as.numeric(sig_only[[logfc_col]]), decreasing = TRUE), ]
  top_20_up       <- head(ordered_up_all, 20)
  
  # --- Step 3: Get ALL Down-regulated sorted (Lowest negative logFC to highest) ---
  ordered_down_all <- sig_only[order(as.numeric(sig_only[[logfc_col]]), decreasing = FALSE), ]
  top_20_down       <- head(ordered_down_all, 20)
  
  # --- Step 4: Combine top slices into the main heatmap data frame ---
  heatmap_df <- rbind(top_20_up, top_20_down)
  
  # --- Step 5: Base numeric matrix (plot_mat) ---
  plot_mat <- matrix(c(as.numeric(heatmap_df[[logfc_col]]), 
                       as.numeric(heatmap_df[[adj_p_col]])), 
                     ncol = 2)
  colnames(plot_mat) <- c("LogFC", "Significance")
  rownames(plot_mat) <- rownames(heatmap_df)
  
  # --- Step 6: Text Display Matrix (display_mat) ---
  display_mat <- matrix("", nrow = nrow(plot_mat), ncol = ncol(plot_mat))
  display_mat[, 1] <- as.character(round(plot_mat[, 1], 2)) 
  display_mat[, 2] <- formatC(plot_mat[, 2], format = "e", digits = 2) 
  colnames(display_mat) <- colnames(plot_mat)
  rownames(display_mat) <- rownames(plot_mat)
  
  # --- Step 7: Color Matrix (color_mat) ---
  color_mat <- cbind(plot_mat[, 1], plot_mat[, 1]) 
  colnames(color_mat) <- colnames(plot_mat)
  rownames(color_mat) <- rownames(plot_mat)
  
  # --- Step 8: Dynamic Variable Names ---
  up_all_var_name   <- paste0("ordered.up.all.", comp)   
  down_all_var_name <- paste0("ordered.down.all.", comp) 
  up_var_name       <- paste0("top.20.up.", comp)         
  down_var_name     <- paste0("top.20.down.", comp)       
  df_var_name       <- paste0("heatmap.df.", comp)       
  plot_var_name     <- paste0("plot.mat.", comp)
  display_var_name  <- paste0("display.mat.", comp)
  color_var_name    <- paste0("color.mat.", comp)
  
  # Send all individual files and matrices directly to your R workspace
  assign(up_all_var_name, ordered_up_all, envir = .GlobalEnv)     
  assign(down_all_var_name, ordered_down_all, envir = .GlobalEnv) 
  assign(up_var_name, top_20_up, envir = .GlobalEnv)     
  assign(down_var_name, top_20_down, envir = .GlobalEnv) 
  assign(df_var_name, heatmap_df, envir = .GlobalEnv)   
  assign(plot_var_name, plot_mat, envir = .GlobalEnv)
  assign(display_var_name, display_mat, envir = .GlobalEnv)
  assign(color_var_name, color_mat, envir = .GlobalEnv)
  
  # --- Step 9: EXPANDED REPORTING (Prints dim and head for all 8 files) ---
  cat(paste0("\n========================================================================\n",
             "VERIFICATION REPORT FOR COMPARISON: ", comp, "\n",
             "========================================================================\n\n"))
  
  # 1. ordered.up.all
  cat(paste0("Variable Name: ", up_all_var_name, " | Dimensions: ", paste(dim(ordered_up_all), collapse=" x "), "\n"))
  print(head(ordered_up_all))
  cat("\n----------------------------------------------------\n")
  
  # 2. ordered.down.all
  cat(paste0("Variable Name: ", down_all_var_name, " | Dimensions: ", paste(dim(ordered_down_all), collapse=" x "), "\n"))
  print(head(ordered_down_all))
  cat("\n----------------------------------------------------\n")
  
  # 3. top.20.up
  cat(paste0("Variable Name: ", up_var_name, " | Dimensions: ", paste(dim(top_20_up), collapse=" x "), "\n"))
  print(head(top_20_up))
  cat("\n----------------------------------------------------\n")
  
  # 4. top.20.down
  cat(paste0("Variable Name: ", down_var_name, " | Dimensions: ", paste(dim(top_20_down), collapse=" x "), "\n"))
  print(head(top_20_down))
  cat("\n----------------------------------------------------\n")
  
  # 5. heatmap.df
  cat(paste0("Variable Name: ", df_var_name, " | Dimensions: ", paste(dim(heatmap_df), collapse=" x "), "\n"))
  print(head(heatmap_df))
  cat("\n----------------------------------------------------\n")
  
  # 6. plot.mat
  cat(paste0("Variable Name: ", plot_var_name, " | Dimensions: ", paste(dim(plot_mat), collapse=" x "), "\n"))
  print(head(plot_mat))
  cat("\n----------------------------------------------------\n")
  
  # 7. display.mat
  cat(paste0("Variable Name: ", display_var_name, " | Dimensions: ", paste(dim(display_mat), collapse=" x "), "\n"))
  print(head(display_mat))
  cat("\n----------------------------------------------------\n")
  
  # 8. color.mat
  cat(paste0("Variable Name: ", color_var_name, " | Dimensions: ", paste(dim(color_mat), collapse=" x "), "\n"))
  print(head(color_mat))
  cat("\n========================================================================\n\n")
}

