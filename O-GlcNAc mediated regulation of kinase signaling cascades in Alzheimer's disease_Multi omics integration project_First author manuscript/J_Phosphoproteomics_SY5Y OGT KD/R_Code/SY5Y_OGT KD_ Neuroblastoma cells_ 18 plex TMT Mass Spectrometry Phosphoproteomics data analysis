# ---------------------------------------------------------------------------------------#
# For Loop: Run KSEA (Kinase-Substrate Enrichment Analysis) for All 7 Comparisons
# ---------------------------------------------------------------------------------------#
# Install KSEAapp if you haven't already:
install.packages("KSEAapp")
library(KSEAapp)

# 1. Use your established list of 7 treatment comparison names
comparisons <- c(
  "GFPTEN.GFPCTRL", 
  "OGTTEN.OGTCTRL", 
  "ROGTTEN.ROGTCTRL", 
  "OGTCTRL.GFPCTRL", 
  "OGTTEN.GFPTEN", 
  "ROGTCTRL.GFPCTRL", 
  "ROGTTEN.GFPTEN"
)

# 2. Run the loop to process KSEA
for (comp in comparisons) {
  
  # Identify column names in your original pdea2$tt data frame
  logfc_col <- comp
  p_col     <- paste0("P.Value.", comp) # KSEA uses raw P.Value, not adjusted
  
  # --- Step A: Reconstruct a clean dataset formatted exactly for KSEAapp ---
  # KSEA needs columns: Protein, Gene, Site, LogFC, P.Value
  ksea_input <- data.frame(
    Protein = as.character(pdea2$tt$Accession),
    FullSymbol = as.character(pdea2$tt$Symbol),
    LogFC   = as.numeric(pdea2$tt[[logfc_col]]),
    P.Value = as.numeric(pdea2$tt[[p_col]]),
    stringsAsFactors = FALSE
  )
  
  # Clean up any row names that might mess up string splits
  rownames(ksea_input) <- NULL
  
  # --- Step B: Split 'AAAS_S495' into 'AAAS' (Gene) and 'S495' (Site) ---
  # We search for the underscore character "_" to split the text
  split_symbols <- strsplit(ksea_input$FullSymbol, "_")
  
  # Extract the Gene Symbol (first part before the underscore)
  ksea_input$Gene <- sapply(split_symbols, function(x) x[1])
  
  # Extract the Phospho-site (second part after the underscore)
  ksea_input$Site <- sapply(split_symbols, function(x) x[2])
  
  # --- Step C: Final Column Cleanup for KSEAapp ---
  # Drop the temporary FullSymbol column and keep only the required layout
  ksea_input <- ksea_input[, c("Protein", "Gene", "Site", "LogFC", "P.Value")]
  
  # Drop any rows that have missing values in critical columns
  ksea_input <- ksea_input[complete.cases(ksea_input[, c("Gene", "Site", "LogFC")]), ]
  
  # --- Step D: Execute KSEA Analysis ---
  # This automatically matches your data against the default PhosphoSitePlus database
  ksea_results <- KSEA.Complete(
    KSData = KSEA.Scores,          # Uses the built-in database from the package
    PX = ksea_input,               # Your formatted dataset
    NetworKIN = FALSE,             # Set TRUE if you have NetworKIN predictions loaded
    NetworKIN_N_cutoff = 2,        
    m.cutoff = 2,                  # Minimum number of substrates required to score a kinase
    p.cutoff = 0.05                # Significance threshold for output plotting
  )
  
  # --- Step E: Save the Results to Global Workspace ---
  # Create custom output variable names
  output_var_name <- paste0("ksea.results.", comp)
  
  # Assign the final output list to your global workspace
  assign(output_var_name, ksea_results, envir = .GlobalEnv)
  
  # Print progress update
  cat(paste0("Successfully finished KSEA for: ", comp, 
             " | Created variable: ", output_var_name, "\n"))
}

