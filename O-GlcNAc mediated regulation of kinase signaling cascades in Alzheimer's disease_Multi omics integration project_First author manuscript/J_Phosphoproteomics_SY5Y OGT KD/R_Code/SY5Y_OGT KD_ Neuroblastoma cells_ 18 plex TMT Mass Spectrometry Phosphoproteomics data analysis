# SiteID = paste0(ProteinAccession_clean, "_", SiteCombined)

SiteID = purrr::pmap_chr(
  
  #pmap = parallel map across multiple inputs; chr = return character output
  
  list(ProteinAccession_clean, raw_sites, SiteCombined),
  function(prot_col, site_col, SiteComb) {
    
    #prot_col=ProteinAccession_clean Q8NE71;Q5STZ8; 
    #site_col=raw_sites = Phospho [S151; S153]; Phospho [S149; S151]
    #SiteComb =SiteCombined = S151/153/149/151
    
    if (is.na(prot_col) | is.na(SiteComb)) return(NA_character_)
    
    if (!str_detect(prot_col, ";")) {
      return(paste0(prot_col, "_", SiteComb))
      
      #if did not detect ; in Q8NE71;Q5STZ8 i.e; Q8NE71 only detected, 
      #Paste Q8NE71_S151/153 (ProteinAccession_clean and Site Combined)
      
    }
    
    # 1. Split proteins into a vector
    prots <- str_split(prot_col, ";")[[1]] #protol=ProteinAccession_clean = Q8NE71;Q5STZ8
    
    #str_split returns a LIST containing one character vector
    #[[1]] = extracts items inside the list
    #If you forgot the [[1]] and tried to use prots[1], you would get the entire list back
    #instead of the first protein ID. Using [[1]] ensures you are working with the data itself rather than the "container" it came in.
    
    #prots - isolate individual protein accessions when multiple proteins are listed in a single cell with ;
    #prot_col=Q8NE71;Q5STZ8 becomes
    #O/P: prots= "Q8NE71" "Q5STZ8"
    
    # 2. Split raw sites into individual groups 
    phospho_parts <- str_split(site_col, "(?<=\\]);\\s*") #raw_sites=sit_col
    
    #site_col=raw_sites =  Phospho [S151; S153]; Phospho [S149; S151]
    
    # (?<=\\]) = look for: after ] if find ; \\s=space *= any no of times , 
    #splt string Phospho [S151; S153]; Phospho [S149; S151]
    
    #O/P phospho_parts="Phospho [S151; S153]" "Phospho [S149; S151]"
    
    # 3. Extract content inside brackets (e.g., [S151; S153] becomes [S151/S153])
    clean_sites <- str_extract(phospho_parts, "(?<=\\[).*(?=\\])") %>% 
    str_replace_all(";", "/")
    
    #str_extract = pulls everything within bracket
    #. (The Dot):  matches any single character (except for a newline), *= any no of times
    #str_replace_all(";", "/") replaces ; with /
    #phospho_parts="Phospho [S151; S153]" "Phospho [S149; S151]" becomes
    #O/P clean_sites = "S151/S153" "S149/S151"
    
    # 4. Combine: Protein_Site:
    combined_vec <- paste(prots, clean_sites, sep = "_")
    
    #O/P: prots= "Q8NE71" "Q5STZ8"
    #O/P clean_sites = "S151/S153" "S149/S151"
    #O/P combined_vec = "Q8NE71_S151/S153" "Q5STZ8_S149/S151"
    
    # 5. Collapse back to one string: 
    return(paste(combined_vec, collapse = ";"))
    
    #O/P combined_vec = "Q8NE71_S151/S153" "Q5STZ8_S149/S151"
    #O/P SiteID = "Q8NE71_S151/S153;Q5STZ8_S149/S151"
    
  }))
     
