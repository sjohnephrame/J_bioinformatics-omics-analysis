# 2. Run the loop to generate the 14 logFC-filtered data frames
for (comp in comparisons) {
  
  # Construct the input variable name from your previous loop
  input_var_name <- paste0("rem.sort.updown.", comp)
  
  # Fetch the existing data frame from your global environment
  current_df <- get(input_var_name, envir = .GlobalEnv)
  
  # Map the exact logFC column name matching your structure
  logfc_col <- paste0("logFC.", comp)
  
  # Force conversion of the logFC column to numeric just to ensure safe subsetting
  current_df[[logfc_col]] <- as.numeric(current_df[[logfc_col]])
  
  # --- Filter Up-regulated hits (> 0.58) ---
  # which() naturally drops any structural NAs safely
  up_df <- current_df[which(current_df[[logfc_col]] > 0.58), ]
  
  # --- Filter Down-regulated hits (< -0.58) ---
  down_df <- current_df[which(current_df[[logfc_col]] < -0.58), ]
  
  # Define the new custom variable name strings matching your pattern
  up_var_name   <- paste0("logFC.great.", comp)
  down_var_name <- paste0("logFC.less.", comp)
  
  # Assign both resulting data frames directly to your workspace
  assign(up_var_name, up_df, envir = .GlobalEnv)
  assign(down_var_name, down_df, envir = .GlobalEnv)
  
  # Console status update to check your split sizes instantly
  cat(paste0("Comparison: ", comp, "\n",
             "  -> ", up_var_name, " Dim: [", nrow(up_df), " x ", ncol(up_df), "]\n",
             "  -> ", down_var_name, " Dim: [", nrow(down_df), " x ", ncol(down_df), "]\n\n"))
}

